                                                                                    <script>
                                                                                        const DOWNLOAD_MENU = document.getElementById("download-menu");
                                                                                        let SAVE_ID = "" || false;
                                                                                        const actionInputs = document.querySelectorAll("input[name='action-option'], input[data-sub-action]");
                                                                                        const saveOptions = document.querySelector("[data-save-options]");
                                                                                        const downloadOptions = document.querySelector("[data-download-options]");
                                                                                        const saveParamsOptions = document.querySelector("[data-save-params-options]");
                                                                                        const publishOptions = document.querySelector("[data-publish-options]");
                                                                                        const importOptions = document.querySelector("[data-import-options]");
                                                                                        const saveContainer = document.querySelector("[data-save-container]");
                                                                                        const publishContainer = document.querySelector("[data-publish-container]");
                                                                                        const saveParamsContainer = document.querySelector("[data-save-params-container]");
                                                                                        const shareContainer = document.querySelector("[data-share-container]");
                                                                                        const downloadContainer = document.querySelector("[data-download-container]");
                                                                                        const importContainer = document.querySelector("[data-import-container]");

                                                                                        function resolutionVisibility() {
                                                                                            document.querySelector("[data-resolution-container]").style.display = (["scene", "hatch"].includes(params.view)) ? "none" : "";
            }
                                                                                        resolutionVisibility();

                                                                                        // When view changes, preselect the matching download option
                                                                                        let formatSelect = document.getElementById("download-format");
            window.addEventListener("viewChanged", () => {
                                                                                            let view = ["plane", "sphere"].includes(params.view) ? "texture" : params.view;
                                                                                        // 3D view isn't shown as specific menu option but can be downloaded as 'Texture'
                                                                                        let optionValue = formatSelect.querySelector("option[data-view='" + view + "']") ? formatSelect.querySelector("option[data-view='" + view + "']").value : "texture";
                                                                                        if (view !== "3d" && (artx.pro === true || (artx.pro === false && view !== "hatch")))
                                                                                        formatSelect.value = optionValue;
                                                                                        resolutionVisibility();
            }
                                                                                        );

                                                                                        // When a hatch format radio input is clicked in the control panel, set the relevant format in the download menu
                                                                                        if (artx.pro) {
                                                                                            document.querySelectorAll("[data-hatch-format-target]").forEach(function (elem) {
                                                                                                elem.addEventListener("click", function () {
                                                                                                    formatSelect.value = elem.getAttribute("data-hatch-format-target");
                                                                                                });
                                                                                            });
            }

                                                                                        // Hide save from brand users
                                                                                        if (artx.user.type === "brand") {
                                                                                            saveContainer.classList.add("hide-me");
            }

                                                                                        // Update the view when the format is changed
                                                                                        formatSelect.onchange = function() {
                                                                                            params.view = formatSelect.selectedOptions[0].getAttribute("data-view");
                                                                                        resolutionVisibility();
                                                                                        predraw();
            }
                                                                                        ;

                                                                                        function setSaveMenuState(action) {
                if (!action) {
                                                                                            action = getArtxCookieValue("saveMenuState") ? getArtxCookieValue("saveMenuState") : (artx.plugin) ? "import" : "download";
                }
                                                                                        const subAction = document.querySelector("[name='" + action + "-option']:checked") ? document.querySelector("[name='" + action + "-option']:checked").value : action;
                                                                                        document.querySelector("input[value='" + action + "']").checked = true;

                                                                                        // Set visibilities for main radio options
                                                                                        saveParamsContainer.style.display = artx.user ? "flex" : "none";
                                                                                        if (!artx.appdata || (artx.user && (["brand", "admin", "editor"].includes(artx.user.type)))) {
                                                                                            saveContainer.style.display = "flex";
                                                                                        shareContainer.style.display = "flex";
                } else {
                                                                                            saveContainer.style.display = "none";
                                                                                        shareContainer.style.display = "none";
                }
                                                                                        publishContainer.style.display = (["brand", "admin", "editor"].includes(artx.user.type)) ? "flex" : "none";
                                                                                        importContainer.style.display = artx.plugin ? "flex" : "none";
                                                                                        downloadContainer.style.display = !artx.plugin ? "flex" : "none";

                                                                                        // Set visibilities for additional options
                                                                                        saveOptions.style.display = (action === "save") ? "flex" : "none";
                                                                                        saveParamsOptions.style.display = (action === "params") ? "flex" : "none";
                                                                                        publishOptions.style.display = (action === "publish") ? "flex" : "none";
                                                                                        downloadOptions.style.display = (action === "download") ? "flex" : "none";
                                                                                        importOptions.style.display = (action === "import") ? "flex" : "none";

                // Hide all action buttons, and display matching button
                document.querySelectorAll("[data-action]").forEach( (button) => {
                                                                                            button.style.display = "none";
                }
                                                                                        );

                                                                                        if (document.querySelector("[data-action='" + subAction + "']")) {
                                                                                            document.querySelector("[data-action='" + subAction + "']").style.display = "block";
                }

                                                                                        positionMenu(document.getElementById("download"));

                                                                                        document.dispatchEvent(new Event('save-menu-updated'));
            }

            actionInputs.forEach( (input) => {
                                                                                            input.addEventListener("change", () => {
                                                                                                const action = document.querySelector("input[name='action-option']:checked").value;
                                                                                                setArtxCookieValue("saveMenuState", action);
                                                                                                setSaveMenuState(action);
                                                                                            }
                                                                                            );
            }
                                                                                        );

                                                                                        setSaveMenuState();

                                                                                        // Set initial value on pageload
                                                                                        const pixelWidthInput = document.querySelector('[data-pixel-width]');
                                                                                        const pixelHeightInput = document.querySelector('[data-pixel-height]');
                                                                                        pixelWidthInput.value = (artx.pro) ? 2048 : 1024;
                                                                                        // Update the resolution after each drawing to match the canvas aspect ratio, don't set it to the canvas size otherwise it will update the user entered value with the preview width (2048 px)
                                                                                        window.addEventListener("drawComplete", function() {
                                                                                            let canvas = artx.mainTextureGenerator.maps.color.canvas;
                                                                                        let aspect = canvas.width / canvas.height;
                                                                                        let height = Math.round(pixelWidthInput.value / aspect);
                                                                                        pixelHeightInput.value = height;
            });

                                                                                        // Set the correct aspect ratio when resolution is changed
                                                                                        function setResolution(inputElement) {
                const aspectRatio = canvas.width / canvas.height;
                                                                                        if (inputElement === pixelWidthInput) {
                    const widthValue = pixelWidthInput.value;
                                                                                        pixelHeightInput.value = parseInt(widthValue / aspectRatio);
                } else if (inputElement === pixelHeightInput) {
                    const heightValue = pixelHeightInput.value;
                                                                                        pixelWidthInput.value = parseInt(heightValue * aspectRatio);
                }
            }

                                                                                        function sanitiseResolution(container) {
                const maxResolution = get("maxres") ? get("maxres") : 8192;
                                                                                        const width = pixelWidthInput.value;
                                                                                        const height = pixelHeightInput.value;

                // Check input size
                if (width > maxResolution || height > maxResolution) {
                    // Check canvas orientation
                    if (canvas.width > canvas.height) {
                                                                                            pixelWidthInput.value = maxResolution;
                                                                                        setResolution(pixelWidthInput);
                    } else {
                                                                                            pixelHeightInput.value = maxResolution;
                                                                                        setResolution(pixelHeightInput);
                    }
                }
            }

                                                                                        // Add event listener to all resolution containers
                                                                                        document.querySelectorAll('[data-resolution-container]').forEach(function(container) {
                                                                                            container.querySelectorAll('[data-pixel-width], [data-pixel-height]').forEach(function (input) {
                                                                                                input.addEventListener('keyup', function (event) {
                                                                                                    setResolution(event.target);
                                                                                                });

                                                                                                input.addEventListener('change', function () {
                                                                                                    sanitiseResolution(container);
                                                                                                });
                                                                                            });
            });
                                                                                    </script>
